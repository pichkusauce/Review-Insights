{
  "manifest_version": 3,
  "name": "Review Insights",
  "version": "1.0",
  "description": "Analyze product reviews easily",

  "action": {
    "default_popup": "popup.html"
  },

  "background": {
    "service_worker": "src/background.js"
  },

  "permissions": ["activeTab", "scripting"],

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content.js"]
    }
  ]
}
